<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- 通知监听权限（用于跨 App 获取歌曲信息） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:padding="14dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▎通知监听权限"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="获取音乐 App 的播放信息（标题、歌手、封面等）"
                android:textSize="12sp"
                android:textColor="#999999"
                android:paddingTop="2dp" />
            <Button android:id="@+id/settingsPermBtn"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="8dp"
                android:text="前往设置开启"
                android:textSize="12sp"
                android:backgroundTint="#6200EE" />
        </LinearLayout>

        <!-- 悬浮窗权限 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:padding="14dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▎悬浮窗权限"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="在其他应用上方显示歌词"
                android:textSize="12sp"
                android:textColor="#999999"
                android:paddingTop="2dp" />
            <Button android:id="@+id/settingsOverlayBtn"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="8dp"
                android:text="前往设置开启"
                android:textSize="12sp"
                android:backgroundTint="#FF9800" />
        </LinearLayout>

        <!-- 屏幕光晕 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:padding="14dp"
            android:layout_marginTop="6dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▎屏幕光晕"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="跟随音乐的透明屏幕边框光晕效果 (需悬浮窗权限)"
                android:textSize="12sp"
                android:textColor="#999999"
                android:paddingBottom="8dp" />
            <Button android:id="@+id/settingsWallpaperBtn"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="8dp"
                android:text="开启屏幕光晕"
                android:textSize="12sp"
                android:backgroundTint="#E91E63" />

            <TextView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="光晕亮度"
                android:textSize="13sp"
                android:textColor="#757575"
                android:paddingTop="12dp" />
            <SeekBar android:id="@+id/glowIntensitySeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50" />
            <TextView android:id="@+id/glowIntensityLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="end" />

            <TextView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="扩散深度"
                android:textSize="13sp"
                android:textColor="#757575"
                android:paddingTop="8dp" />
            <SeekBar android:id="@+id/glowSpreadSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50" />
            <TextView android:id="@+id/glowSpreadLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="end" />

            <TextView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="色相变化速度"
                android:textSize="13sp"
                android:textColor="#757575"
                android:paddingTop="8dp" />
            <SeekBar android:id="@+id/glowHueSpeedSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="30" />
            <TextView android:id="@+id/glowHueSpeedLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="end" />

            <TextView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="粒子数量"
                android:textSize="13sp"
                android:textColor="#757575"
                android:paddingTop="8dp" />
            <SeekBar android:id="@+id/glowParticlesSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="30" />
            <TextView android:id="@+id/glowParticlesLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="end" />

            <TextView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Beat 灵敏度"
                android:textSize="13sp"
                android:textColor="#757575"
                android:paddingTop="8dp" />
            <SeekBar android:id="@+id/glowBeatSensSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50" />
            <TextView android:id="@+id/glowBeatSensLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="end" />
        </LinearLayout>

        <!-- 悬浮窗样式设置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:padding="14dp"
            android:layout_marginTop="6dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▎悬浮窗样式"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="自定义歌词显示效果"
                android:textSize="12sp"
                android:textColor="#999999"
                android:paddingBottom="8dp" />

            <TextView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="文本样式"
                android:textSize="13sp"
                android:textColor="#757575" />
            <RadioGroup
                android:id="@+id/styleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton android:id="@+id/styleNormal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="经典白" android:textSize="13sp" />
                <RadioButton android:id="@+id/styleNeon" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="霓虹青" android:textSize="13sp" />
                <RadioButton android:id="@+id/styleRainbow" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="彩虹" android:textSize="13sp" />
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="打字效果"
                    android:textSize="13sp"
                    android:textColor="#757575" />
                <Switch android:id="@+id/typingSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="字体大小"
                android:textSize="13sp"
                android:textColor="#757575"
                android:paddingTop="8dp" />
            <SeekBar android:id="@+id/fontSizeSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="20"
                android:progress="8" />
            <TextView android:id="@+id/fontSizeLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="20sp"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="end" />
        </LinearLayout>

        <!-- 关于 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="1dp"
            android:padding="14dp"
            android:layout_marginTop="6dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▎关于"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="音乐悬浮窗 v1.0.0"
                android:textSize="13sp"
                android:textColor="#757575"
                android:paddingTop="4dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
