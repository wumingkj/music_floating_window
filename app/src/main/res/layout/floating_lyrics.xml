<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatingRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_bg"
    android:padding="14dp"
    android:minWidth="200dp"
    android:elevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/floatingAlbumArt"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher"
            android:contentDescription="封面" />
        <TextView
            android:id="@+id/floatingSongTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginStart="8dp" />
        <TextView
            android:id="@+id/floatingCloseBtn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="\u2715"
            android:textSize="14sp"
            android:textColor="#88FFFFFF"
            android:gravity="center" />
    </LinearLayout>

    <com.wuming.musicFW.ui.GlowTextView
        android:id="@+id/floatingLyricText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="歌词加载中..."
        android:textSize="20sp"
        android:textColor="#FFD700"
        android:paddingTop="4dp"
        android:maxWidth="300dp" />
</LinearLayout>
